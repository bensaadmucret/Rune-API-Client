{
  "name": "--",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --reporter=verbose",
    "test:staged": "vitest --run --reporter=verbose",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,tsx,js,css,md}\"",
    "type-check": "vue-tsc --noEmit",
    "audit": "cd src-tauri && cargo audit",
    "precommit": "npm run lint && npm run type-check && npm run audit",
    "quality": "npm run lint && npm run type-check && npm run test:ci",
    "quality:fix": "npm run lint:fix && npm run format",
    "rust:lint": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "rust:lint:fix": "cd src-tauri && cargo clippy --all-targets --all-features --fix -- -D warnings",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:fmt:check": "cd src-tauri && cargo fmt -- --check",
    "rust:check": "cd src-tauri && cargo check --all-targets --all-features",
    "rust:quality": "npm run rust:fmt && npm run rust:lint",
    "rust:fix": "npm run rust:fmt && npm run rust:lint:fix",
    "rust:test": "cd src-tauri && cargo test --all-targets --all-features",
    "rust:ci": "npm run rust:fmt:check && npm run rust:lint && npm run rust:test",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "release": "npm run build && cd src-tauri && cargo tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "@tauri-apps/plugin-fs": "2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.0.0",
    "ico-endec": "^0.1.6",
    "lint-staged": "^15.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^7.0.0",
    "vite": "^6.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{vue,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,css,md}": [
      "prettier --write"
    ]
  }
}
