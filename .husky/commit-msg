#!/bin/sh
# Commit-msg hook - validate commit message format

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Check commit message length
if [ ${#COMMIT_MSG} -lt 10 ]; then
    echo "❌ Commit message too short (min 10 characters)"
    exit 1
fi

# Check conventional commit format (optional)
# FORMAT: type(scope): description
if ! echo "$COMMIT_MSG" | grep -qE "^(feat|fix|docs|style|refactor|test|chore|ci|build|perf)(\(.+\))?: .+"; then
    echo "⚠️ Consider using conventional commits:"
    echo "   feat: new feature"
    echo "   fix: bug fix"
    echo "   docs: documentation"
    echo "   test: tests"
    echo "   refactor: code refactoring"
    # Don't fail, just warn
fi

echo "✅ Commit message OK"
